<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gemma Chat</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #0a0a0f;
  color: #e0e0e0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-bottom: 1px solid #2a2a4a;
  padding: 16px 24px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.header-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #e94560, #ff6b9d);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

h1 { font-size: 18px; font-weight: 600; color: #fff; }

.settings-btn {
  margin-left: auto;
  background: #2a2a4a;
  border: 1px solid #3a3a5a;
  color: #a0a0c0;
  padding: 8px 16px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
}

.settings-btn:hover { background: #3a3a5a; }

#settings {
  background: #12121a;
  border-bottom: 1px solid #2a2a4a;
  padding: 16px 24px;
  display: none;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  flex-shrink: 0;
}

#settings.show { display: flex; }

#settings label {
  font-size: 12px;
  color: #8080a0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

#settings input {
  background: #1a1a2e;
  border: 1px solid #3a3a5a;
  color: #e0e0e0;
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 14px;
  font-family: monospace;
  width: 320px;
}

#settings input:focus { outline: none; border-color: #e94560; }

#settings button {
  background: #e94560;
  color: white;
  border: none;
  padding: 8px 20px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 13px;
  align-self: flex-end;
}

#settings button:hover { background: #ff6b6b; }

#chat {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.message {
  max-width: 700px;
  width: 100%;
  margin: 0 auto;
  display: flex;
  gap: 12px;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.message.user { flex-direction: row-reverse; }

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.message.user .avatar { background: linear-gradient(135deg, #4a90d9, #6ab0ff); }
.message.assistant .avatar { background: linear-gradient(135deg, #e94560, #ff6b9d); }

.bubble {
  background: #1a1a2e;
  border: 1px solid #2a2a4a;
  border-radius: 14px;
  padding: 12px 16px;
  font-size: 15px;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  max-width: calc(100% - 60px);
}

.message.user .bubble {
  background: #1e2a3e;
  border-color: #2a4060;
}

.bubble.error { color: #ff6b6b; border-color: #ff6b6b40; }

#input-area {
  background: #0f0f18;
  border-top: 1px solid #2a2a4a;
  padding: 16px 24px;
  flex-shrink: 0;
}

.input-row {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  gap: 12px;
}

#msg {
  flex: 1;
  background: #1a1a2e;
  border: 1px solid #2a2a4a;
  color: #e0e0e0;
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 15px;
  font-family: inherit;
  resize: none;
  min-height: 48px;
  max-height: 150px;
  line-height: 1.5;
}

#msg:focus { outline: none; border-color: #e94560; }
#msg::placeholder { color: #606080; }

#send {
  background: #e94560;
  color: white;
  border: none;
  width: 48px;
  height: 48px;
  border-radius: 12px;
  cursor: pointer;
  font-size: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  flex-shrink: 0;
}

#send:hover { background: #ff6b6b; }
#send:disabled { background: #3a3a5a; cursor: not-allowed; }

.thinking {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #8080a0;
  font-size: 13px;
  padding: 8px 0;
}

.dots {
  display: flex;
  gap: 4px;
}

.dots span {
  width: 6px;
  height: 6px;
  background: #8080a0;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.dots span:nth-child(1) { animation-delay: 0s; }
.dots span:nth-child(2) { animation-delay: 0.2s; }
.dots span:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1.2); opacity: 1; }
}

@media (max-width: 600px) {
  #settings input { width: 100%; }
  .bubble { max-width: calc(100% - 48px); font-size: 14px; }
  header, #input-area, #settings { padding-left: 16px; padding-right: 16px; }
}
</style>
</head>
<body>

<header>
  <div class="header-icon">G</div>
  <h1>Gemma Chat</h1>
  <button class="settings-btn" onclick="toggleSettings()">Settings</button>
</header>

<div id="settings">
  <label>
    API URL
    <input type="text" id="apiUrl" placeholder="https://your-api.com/v1">
  </label>
  <label>
    Model
    <input type="text" id="modelName" placeholder="gemma-2-2b-it-abliterated-Q4_K_M.gguf">
  </label>
  <button onclick="saveSettings()">Save</button>
</div>

<div id="chat"></div>

<div id="input-area">
  <div class="input-row">
    <textarea id="msg" placeholder="問我任何事..." rows="1"></textarea>
    <button id="send" onclick="sendMsg()">&#10148;</button>
  </div>
</div>

<script>
const chat = document.getElementById('chat');
const msgInput = document.getElementById('msg');
const sendBtn = document.getElementById('send');

const DEFAULT_API = 'https://09d9f173ceb1e7.lhr.life/1edf5d12423b60e8';
const DEFAULT_MODEL = 'gemma-2-2b-it-abliterated-Q4_K_M.gguf';

let apiUrl = localStorage.getItem('gemma_api') || DEFAULT_API;
let model = localStorage.getItem('gemma_model') || DEFAULT_MODEL;

document.getElementById('apiUrl').value = apiUrl;
document.getElementById('modelName').value = model;

function toggleSettings() {
  document.getElementById('settings').classList.toggle('show');
}

function saveSettings() {
  apiUrl = document.getElementById('apiUrl').value.trim();
  model = document.getElementById('modelName').value.trim();
  localStorage.setItem('gemma_api', apiUrl);
  localStorage.setItem('gemma_model', model);
  document.getElementById('settings').classList.remove('show');
}

function addMessage(role, content, isError) {
  const div = document.createElement('div');
  div.className = `message ${role}`;
  div.innerHTML = `
    <div class="avatar">${role === 'user' ? 'U' : 'G'}</div>
    <div class="bubble${isError ? ' error' : ''}">${escapeHtml(content)}</div>
  `;
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

function addThinking() {
  const div = document.createElement('div');
  div.className = 'message assistant';
  div.id = 'thinking';
  div.innerHTML = `
    <div class="avatar">G</div>
    <div class="bubble">
      <div class="thinking">
        <div class="dots"><span></span><span></span><span></span></div>
        思考中...
      </div>
    </div>
  `;
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

function removeThinking() {
  const el = document.getElementById('thinking');
  if (el) el.remove();
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

msgInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMsg();
  }
});

async function sendMsg() {
  const text = msgInput.value.trim();
  if (!text || sendBtn.disabled) return;

  addMessage('user', text);
  msgInput.value = '';
  msgInput.style.height = 'auto';
  sendBtn.disabled = true;

  addThinking();

  try {
    const res = await fetch(apiUrl + '/v1/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: model,
        messages: [{ role: 'user', content: text }],
        max_tokens: 512,
        stream: false
      })
    });

    removeThinking();

    if (!res.ok) {
      const err = await res.text();
      addMessage('assistant', '錯誤 ' + res.status + ': ' + err.substring(0, 200), true);
    } else {
      const data = await res.json();
      const reply = data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content;
      addMessage('assistant', reply || JSON.stringify(data).substring(0, 300));
    }
  } catch(e) {
    removeThinking();
    addMessage('assistant', '網路錯誤: ' + e.message, true);
  }

  sendBtn.disabled = false;
  msgInput.focus();
}

// Auto-resize textarea
msgInput.addEventListener('input', () => {
  msgInput.style.height = 'auto';
  msgInput.style.height = Math.min(msgInput.scrollHeight, 150) + 'px';
});
</script>
</body>
</html>
